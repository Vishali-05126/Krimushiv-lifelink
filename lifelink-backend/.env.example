# Copy this file to .env and fill values before starting the server
# MongoDB connection string. Example (MongoDB Atlas).
# MONGO_URI is also accepted for compatibility, but MONGODB_URI is preferred.
# MONGODB_URI=mongodb+srv://<user>:<password>@cluster0.mongodb.net/lifelink?retryWrites=true&w=majority
MONGODB_URI=

# Server port (default 5000)
PORT=5000

# JWT secret for signing tokens (choose a strong secret)
JWT_SECRET=change_me_to_a_secure_value
JWT_EXPIRES_IN=7d

# Node environment (development/production)
NODE_ENV=development

# Optional: Google Maps API key for geocoding (optional)
GOOGLE_MAPS_API_KEY=
