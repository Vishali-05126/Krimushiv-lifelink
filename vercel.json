{
  "version": 2,
  "builds": [
    { "src": "api/index.js", "use": "@vercel/node" },
    { "src": "lifelink-frontend/**/*.html", "use": "@vercel/static" },
    { "src": "lifelink-frontend/**/*.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "source": "/api/(.*)", "dest": "/api/index.js" },
    { "handle": "filesystem" },
    { "source": "/(.*)", "dest": "/lifelink-frontend/$1" }
  ],
  "env": {
    "FILE_DB_FALLBACK": "true",
    "JWT_SECRET": "lifelink-vercel-secret-key"
  }
}